generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  password         String
  role             UserRole          @default(ADMIN)
  emailVerified    DateTime?         @map("email_verified")
  image            String?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  lastLoginAt      DateTime?         @map("last_login_at")
  accounts         Account[]
  auditLogs        AuditLog[]
  contentTemplates ContentTemplate[] @relation("TemplateCreator")
  documents        Document[]        @relation("DocumentUploader")
  media            Media[]           @relation("MediaUploader")
  newsArticles     News[]            @relation("NewsAuthor")
  notifications    Notification[]
  sessions         Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model News {
  id              String                   @id @default(cuid())
  title           String
  slug            String                   @unique
  excerpt         String?
  content         String
  coverImage      String?
  status          ContentStatus            @default(DRAFT)
  featured        Boolean                  @default(false)
  publishedAt     DateTime?                @map("published_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  authorId        String                   @map("author_id")
  metaTitle       String?                  @map("meta_title")
  metaDescription String?                  @map("meta_description")
  searchVector    Unsupported("tsvector")? @map("search_vector")
  author          User                     @relation("NewsAuthor", fields: [authorId], references: [id])

  @@index([slug])
  @@index([status, publishedAt(sort: Desc)])
  @@index([authorId])
  @@map("news")
}

model Event {
  id               String                   @id @default(cuid())
  title            String
  slug             String                   @unique
  description      String
  eventDate        DateTime                 @map("event_date")
  eventTime        String?                  @map("event_time")
  location         String?
  address          String?
  coverImage       String?
  status           ContentStatus            @default(DRAFT)
  featured         Boolean                  @default(false)
  registrationOpen Boolean                  @default(false) @map("registration_open")
  maxParticipants  Int?                     @map("max_participants")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  searchVector     Unsupported("tsvector")? @map("search_vector")

  @@index([slug])
  @@index([eventDate(sort: Desc)])
  @@index([status])
  @@map("events")
}

model Document {
  id             String                   @id @default(cuid())
  title          String
  description    String?
  filename       String
  filepath       String                   @unique
  fileSize       Int
  mimeType       String                   @map("mime_type")
  category       String?
  uploadedById   String                   @map("uploaded_by_id")
  uploadedAt     DateTime                 @default(now()) @map("uploaded_at")
  downloadCount  Int                      @default(0) @map("download_count")
  lastDownloadAt DateTime?                @map("last_download_at")
  searchVector   Unsupported("tsvector")? @map("search_vector")
  uploadedBy     User                     @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@index([category])
  @@index([uploadedAt(sort: Desc)])
  @@map("documents")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValues  String?  @map("old_values")
  newValues  String?  @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType @default(INFO)
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  filepath     String   @unique
  url          String
  mimeType     String   @map("mime_type")
  size         Int
  width        Int?
  height       Int?
  folder       String?
  tags         String[]
  focalPointX  Float?   @map("focal_point_x")
  focalPointY  Float?   @map("focal_point_y")
  alt          String?
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  uploadedBy   User     @relation("MediaUploader", fields: [uploadedById], references: [id])

  @@index([folder])
  @@index([uploadedById])
  @@index([createdAt(sort: Desc)])
  @@map("media")
}

model ContentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("generale")
  entityType  String   @map("entity_type")
  content     Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by")
  creator     User?    @relation("TemplateCreator", fields: [createdBy], references: [id])

  @@index([category])
  @@index([entityType])
  @@index([createdAt(sort: Desc)])
  @@map("content_templates")
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}
